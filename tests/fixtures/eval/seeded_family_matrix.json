{
  "version": 1,
  "cases": [
    {
      "name": "capacitor_low_voltage",
      "description": "Lower C1 rated-voltage token below the inferred 3.3 V rail.",
      "family": "capacitor",
      "fixture_name": "passive_pst",
      "netlist": "$fixture",
      "mutation_target": "bom",
      "mutation_old": "0.1uF 25V",
      "mutation_new": "0.1uF 1V",
      "expected": {
        "refdes": "C1",
        "kind": "component",
        "check": "capacitor_voltage_margin",
        "status": "ERROR"
      }
    },
    {
      "name": "capacitor_unparseable_value",
      "description": "Replace C1 capacitance text with an unparseable token.",
      "family": "capacitor",
      "fixture_name": "passive_pst",
      "netlist": "$fixture",
      "mutation_target": "bom",
      "mutation_old": "0.1uF 25V",
      "mutation_new": "TBD 25V",
      "expected": {
        "refdes": "C1",
        "kind": "component",
        "check": "capacitor_value_parse",
        "status": "WARN"
      }
    },
    {
      "name": "resistor_package_conflict",
      "description": "Change R1's schematic package from resistor-like to capacitor-like.",
      "family": "resistor",
      "fixture_name": "passive_pst",
      "netlist": "$fixture",
      "mutation_target": "pstchip.dat",
      "mutation_old": "JEDEC_TYPE='R0402';",
      "mutation_new": "JEDEC_TYPE='C0402';",
      "expected": {
        "refdes": "R1",
        "kind": "component",
        "check": "resistor_package_presence",
        "status": "WARN"
      }
    },
    {
