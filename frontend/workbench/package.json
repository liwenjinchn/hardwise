{
  "name": "@hardwise/workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:contracts": "node scripts/workbench-contracts.mjs generate",
    "check:contracts": "node scripts/workbench-contracts.mjs check",
    "typecheck": "npm run check:contracts && tsc --noEmit",
    "lint": "npm run typecheck",
    "build": "npm run typecheck && vite build",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:only": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
