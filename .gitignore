# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv-*/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# Env / secrets — .env MUST stay local
.env
.env.*
!.env.example

# IDE / OS
.vscode/
.idea/
.claude/
.codex_work/
.DS_Store
*.swp

# Data — public datasheets and KiCad projects are heavy; do not commit
data/projects/*
data/datasheets/*
!data/projects/.gitkeep
!data/datasheets/.gitkeep
!data/datasheets/README.md
# Exception: the KiCad public demo project IS shipped with the repo so
# `uv run hardwise review data/projects/pic_programmer --rules R001` works
# out of the box for anyone who clones. Other project dirs stay ignored
# (in case company-internal KiCad workspaces ever live under data/projects/).
!data/projects/pic_programmer/
!data/projects/pic_programmer/**

# Local DB / vector store
*.db
data/chroma/

# Generated reports — local outputs
reports/*.md
reports/*.html
reports/*.jsonl
reports/eval/
!reports/.gitkeep

# Eval corpus checkouts — public but large/generated locally
eval/projects/
eval/baselines/*.json

# Sleep Consolidator output — local candidate-rule pool, never auto-promoted.
# `memory/rules.md` is generated at runtime; do not commit a project's worth
# of candidates into the repo.
memory/*.md
!memory/.gitkeep
