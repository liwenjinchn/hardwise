# Upstream API — Anthropic-format protocol via xiaomimimo.com proxy serving MiMo-V2.5
# (Anthropic SDK speaks the protocol; the model behind it is MiMo, not Claude.)
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic

# Tiered model slots — three slots are an architectural pattern; if the upstream
# exposes only one model, all three may point to it. When MiMo ships per-tier
# variants, replace the corresponding value — no code change needed.
HARDWISE_MODEL_FAST=mimo-v2.5
HARDWISE_MODEL_NORMAL=mimo-v2.5
HARDWISE_MODEL_DEEP=mimo-v2.5

# Storage paths (relative to project root)
HARDWISE_DB_PATH=./data/hardwise.db
HARDWISE_VECTOR_DIR=./data/chroma
